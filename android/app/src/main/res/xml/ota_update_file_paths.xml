<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- ota_update saves the APK under <internal>/files/ota_update/<name>.apk
         on most devices. Expose multiple roots so the FileProvider can
         resolve whichever path the plugin actually used. -->
    <files-path           name="ota_update_internal"          path="ota_update/"/>
    <files-path           name="ota_update_internal_root"     path="."/>
    <external-files-path  name="ota_update_external_files"    path="."/>
    <external-path        name="ota_update_external_root"     path="."/>
    <cache-path           name="ota_update_cache"             path="."/>
</paths>
